# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=synapse_dev
DB_USER=postgres
DB_PASSWORD=26221526
DB_SSL=false

# Environment
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_FROM_NAME=ERP Máquinas

# Gmail OAuth 2.0 Configuration (Recommended for Gmail)
# OAuth 2.0 is more secure than App Passwords and is the modern approach
GMAIL_CLIENT_ID=your-gmail-client-id.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token

# Gmail App Password (Fallback option)
# Only used if OAuth 2.0 credentials are not provided
SMTP_PASS=your-app-password

# Setup Instructions:
# 
# Option 1: OAuth 2.0 (Recommended)
# 1. Go to Google Cloud Console: https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable Gmail API
# 4. Create OAuth 2.0 credentials (Desktop application)
# 5. Use OAuth Playground: https://developers.google.com/oauthplayground/
# 6. Authorize Gmail API v1 scope: https://www.googleapis.com/auth/gmail.send
# 7. Exchange authorization code for tokens
# 8. Copy Client ID, Client Secret, and Refresh Token to the variables above
#
# Option 2: App Password (Fallback)
# 1. Enable 2-factor authentication on your Gmail account
# 2. Generate an App Password: https://support.google.com/accounts/answer/185833
# 3. Use the App Password as SMTP_PASS
#
# For other providers:
# - Outlook/Hotmail: smtp-mail.outlook.com, port 587
# - Yahoo: smtp.mail.yahoo.com, port 587
# - Custom SMTP: Use your provider's settings